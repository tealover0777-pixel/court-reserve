rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user belongs to the tenant
    function isTenantMember(tenantId) {
      return request.auth != null && request.auth.token.tenantId == tenantId;
    }

    // Example rule for a collection partitioned by tenantId
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if isTenantMember(tenantId);
    }
    
    // Root-level dimensions collection (Public for now)
    match /dimensions/{dimensionId} {
      allow read, write: if true;
    }

    // Fallback rule for shared collections
    match /{path=**} {
      allow read, write: if request.auth != null && request.auth.token.tenantId == resource.data.tenantId;
    }
  }
}