rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user belongs to the tenant
    function isTenantMember(tenantId) {
      return request.auth != null && request.auth.token.tenantId == tenantId;
    }

    // Helper to check if user is an admin (can be expanded)
    function isAdmin() {
      return request.auth != null; // For now, allow any auth user to be an admin for debugging
    }

    // Tenants collection
    match /tenants/{tenantId} {
      allow read, write: if true;
      
      // Allow access to subcollections
      match /{document=**} {
        allow read, write: if true;
      }
    }
    
    // Global Users collection
    match /global_users/{userId} {
      allow read, write: if true;
    }
    
    // Root-level dimensions collection (Public for now)
    match /dimensions/{dimensionId} {
      allow read, write: if true;
    }

    // Role Types collection (Public for now)
    match /role_types/{roleId} {
      allow read, write: if true;
    }

    // Fallback rule for shared collections
    match /{path=**} {
      allow read, write: if request.auth != null && (resource == null || request.auth.token.tenantId == resource.data.tenantId || isAdmin());
    }
  }
}