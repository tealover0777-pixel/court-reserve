rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /tenants/{tenantId}/branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /courts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
